# Inventory Management AI endpoint
POST http://127.0.0.1:8000/ai/inventory-management
Content-Type: application/json

{
  "inventory": [
    {
      "id": "i1",
      "product": "Product A",
      "quantity": 100,
      "min_stock": 20,
      "max_stock": 200
    },
    {
      "id": "i2",
      "product": "Product B",
      "quantity": 50,
      "min_stock": 10,
      "max_stock": 100
    }
  ],
  "demand_history": [
    {
      "product": "Product A",
      "month": "2023-05",
      "quantity": 50
    },
    {
      "product": "Product A",
      "month": "2023-04",
      "quantity": 45
    },
    {
      "product": "Product B",
      "month": "2023-05",
      "quantity": 30
    },
    {
      "product": "Product B",
      "month": "2023-04",
      "quantity": 25
    }
  ],
  "supplier_lead_times": [
    {
      "supplier": "Supplier X",
      "product": "Product A",
      "lead_time_days": 14
    },
    {
      "supplier": "Supplier Y",
      "product": "Product B",
      "lead_time_days": 7
    }
  ]
}


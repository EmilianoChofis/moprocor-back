# Production Planning AI endpoint
POST http://127.0.0.1:8000/ai/production-planning
Content-Type: application/json

{
  "purchases": [
    {
      "id": "p1",
      "customer": "Customer A",
      "delivery_date": "2023-06-01",
      "boxes": ["b1", "b2"],
      "quantity": 1000
    }
  ],
  "sheets": [
    {
      "id": "s1",
      "width": 1000,
      "length": 2000,
      "ect": "A",
      "anti_humidity": true
    }
  ],
  "boxes": [
    {
      "id": "b1",
      "width": 500,
      "length": 600,
      "height": 400,
      "ect": "A",
      "anti_humidity": true
    },
    {
      "id": "b2",
      "width": 300,
      "length": 400,
      "height": 300,
      "ect": "A",
      "anti_humidity": true
    }
  ]
}

